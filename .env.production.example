# host-node-01 SSH connection
DEPLOY_HOST=root@host-node-01

# Remote directory on host-node-01
REMOTE_DIR=/opt/xotamap

# Docker container settings
CONTAINER_NAME=xotamap
IMAGE_NAME=xotamap:latest
CONTAINER_PORT=127.0.0.1:3082:80

# Public URL
SITE_URL=https://xotamap.oeradio.at/

# Docker command
DOCKER_CMD=docker
